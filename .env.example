# Roboflow API key — required for scripts/download_dataset.py
ROBOFLOW_API_KEY=your_roboflow_api_key_here

# Path to trained model weights (.pt file)
# Local: runs/train/weights/best.pt  |  GitHub Release: download to this path first
MODEL_WEIGHTS_PATH=runs/train/weights/best.pt

# Path to rules configuration
RULES_CONFIG_PATH=rules.yaml

# Logging
LOG_LEVEL=INFO

# Set to False in production
DEBUG=False
